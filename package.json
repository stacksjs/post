{
  "name": "post",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "A modern mail server & utilities.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/post",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/post.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/post/issues"
  },
  "keywords": [
    "mail",
    "server",
    "utilities",
    "development",
    "mailtrap",
    "nodemailer",
    "bun",
    "stacks",
    "typescript",
    "javascript"
  ],
  "exports": {
    ".": {
      "import": "./packages/post/dist/index.js"
    }
  },
  "module": "./packages/post/dist/index.js",
  "types": "./packages/post/dist/index.d.ts",
  "bin": {
    "post": "./packages/post/dist/cli.js"
  },
  "files": [
    "README.md",
    "packages/post/dist"
  ],
  "scripts": {
    "build": "bun --filter './packages/*' build",
    "compile:all": "bun --filter './packages/*' compile",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build && bun run compile:all",
    "test": "bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bun run changelog:generate && bunx bumpx prompt --recursive",
    "typecheck": "bunx tsc --noEmit",
    "dev:docs": "bun --bun vitepress dev docs",
    "build:docs": "bun --bun vitepress build docs",
    "preview:docs": "bun --bun vitepress preview docs",
    "postinstall": "bunx git-hooks"
  },
  "devDependencies": {
    "@stacksjs/docs": "^0.70.23",
    "@stacksjs/clapp": "^0.2.0",
    "typescript": "^5.9.3",
    "better-dx": "^0.2.7"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  },
  "overrides": {
    "unconfig": "0.3.10"
  },
  "workspaces": [
    "packages/*"
  ]
}
